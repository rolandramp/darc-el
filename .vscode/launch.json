{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "DARC-EL: Run",
      "type": "python",
      "request": "launch",
      "program": "${workspaceFolder}/darc-el-backend/src/main.py",
      "console": "integratedTerminal",
      "justMyCode": true,
      "env": {
        "ZOTERO_LIBRARY_ID": "${env:ZOTERO_LIBRARY_ID}",
        "ZOTERO_API_KEY": "${env:ZOTERO_API_KEY}",
        "ZOTERO_LIBRARY_TYPE": "${env:ZOTERO_LIBRARY_TYPE}",
        "ZOTERO_OUTPUT_FILE": "${env:ZOTERO_OUTPUT_FILE}"
      },
      "args": [
        "--llm-config-path",
        "${workspaceFolder}/config/llm_models.yaml"
      ]
    },
    {
      "name": "DARC-EL UI: Run",
      "type": "python",
      "request": "launch",
      "program": "${workspaceFolder}/darc-el-ui/manage.py",
      "args": [
        "runserver",
        "0.0.0.0:8081"
      ],
      "cwd": "${workspaceFolder}/darc-el-ui",
      "console": "integratedTerminal",
      "justMyCode": true,
      "env": {
        "BACKEND_BASE_URL": "http://localhost:8000"
      }
    },
    {
      "name": "DARC-EL: Debug",
      "type": "python",
      "request": "launch",
      "program": "${workspaceFolder}/darc-el-backend/src/main.py",
      "console": "integratedTerminal",
      "justMyCode": false,
      "stopOnEntry": false,
      "env": {
        "ZOTERO_LIBRARY_ID": "${env:ZOTERO_LIBRARY_ID}",
        "ZOTERO_API_KEY": "${env:ZOTERO_API_KEY}",
        "ZOTERO_LIBRARY_TYPE": "${env:ZOTERO_LIBRARY_TYPE}",
        "ZOTERO_OUTPUT_FILE": "${env:ZOTERO_OUTPUT_FILE}"
      },
      "args": [
        "--llm-config-path",
        "${workspaceFolder}/config/llm_models.yaml"
      }
    }
  ]
}
