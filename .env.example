ZOTERO_LIBRARY_ID=your_library_id
ZOTERO_API_KEY=your_api_key
ZOTERO_LIBRARY_TYPE=group

# Neo4j credentials
NEO4J_USER=neo4j
NEO4J_PASS=your_neo4j_password
NEO4J_URI=bolt://neo4j-kg:7687

# LLM / Ollama / OpenAI
LLM_MODEL=ministral-3:3b
LLM_EMBED=nomic-embed-text
LLM_URL=http://ollama-llm:11434
LLM_KEY=your_llm_key
LLAMA_CPP_MODEL=mistralai/Ministral-3-3B-Instruct-2512-GGUF:Q4_K_M
LLM_DEFAULT_PROVIDER=ollama
#LLM_DEFAULT_PROVIDER=openai

# Model for ministral-llama-cpp (optional override)
MINISTRAL_MODEL=mistralai/Ministral-3-3B-Instruct-2512-GGUF:Q4_K_M

# Optional llama.cpp (only if you run the `llama-cpp-service`)
# When `ankigen` runs inside Docker, use the service name on the Compose network:
LLAMA_CPP_URL=http://llama-cpp-backend:8080
# When `ankigen` runs locally on your machine, use the published port:
# LLAMA_CPP_URL=http://localhost:1235
